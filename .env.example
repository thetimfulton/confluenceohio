# ============================================================
# Confluence Ohio — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# In Vercel, set these in Project Settings → Environment Variables.
# ============================================================

# --- Supabase ---
# Local dev: run `npx supabase start` to get these values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Smarty (Address Verification) ---
# Embedded key is publishable (used in browser for autocomplete).
# Auth ID + token are SECRET (used server-side for US Street API).
NEXT_PUBLIC_SMARTY_EMBEDDED_KEY=your-smarty-embedded-key
SMARTY_AUTH_ID=your-smarty-auth-id
SMARTY_AUTH_TOKEN=your-smarty-auth-token

# --- Brevo (Email) ---
BREVO_API_KEY=xkeysib-your-api-key
BREVO_WEBHOOK_SECRET=your-brevo-webhook-secret

# Brevo list IDs — created by: cd packages/email && npx tsx brevo-setup.ts
BREVO_LIST_ALL=1
BREVO_LIST_SIGNERS=2
BREVO_LIST_VERIFIED=3
BREVO_LIST_VOLUNTEERS=4
BREVO_LIST_DONORS=5
BREVO_LIST_RECURRING_DONORS=6     # Recurring donor list — created in Brevo for recurring donor stewardship
BREVO_LIST_ENGAGED=7
BREVO_LIST_DISENGAGED=8
BREVO_LIST_STANDALONE=9

# Brevo template IDs — create templates in Brevo dashboard, then add IDs here.
# See Artifact 07 §3.2 for template specs and required variables.
BREVO_TEMPLATE_EMAIL_VERIFY=1
BREVO_TEMPLATE_WELCOME_1=2
BREVO_TEMPLATE_WELCOME_2=3
BREVO_TEMPLATE_WELCOME_3=4
BREVO_TEMPLATE_WELCOME_4=5
BREVO_TEMPLATE_SIGNER_TO_VOLUNTEER=6
BREVO_TEMPLATE_SIGNER_TO_DONOR=7
BREVO_TEMPLATE_MILESTONE=8
BREVO_TEMPLATE_RE_ENGAGEMENT_1=9
BREVO_TEMPLATE_RE_ENGAGEMENT_2=10
BREVO_TEMPLATE_VOLUNTEER_CONFIRM=11
BREVO_TEMPLATE_VOLUNTEER_ONBOARD_2=12
BREVO_TEMPLATE_STANDALONE_WELCOME=13
BREVO_TEMPLATE_DONATION_THANKS=14
BREVO_TEMPLATE_DONATION_THANKS_RECURRING=15
BREVO_TEMPLATE_ADMIN_NEW_VOLUNTEER=16
BREVO_TEMPLATE_RESEND_VERIFY=17
BREVO_TEMPLATE_VOLUNTEER_ROLE_UPDATE=18
BREVO_TEMPLATE_VOLUNTEER_FIRST_TASK=25     # Volunteer nurture: first task/event invite (Day 7)
BREVO_TEMPLATE_VOLUNTEER_CHECK_IN=26       # Volunteer nurture: check-in email (Day 14)
BREVO_TEMPLATE_SUBSCRIBER_CASE=27          # Subscriber nurture: "The Case in 5 Minutes" (Day 2)
BREVO_TEMPLATE_SUBSCRIBER_PETITION_CTA=28  # Subscriber nurture: petition CTA (Day 5)
BREVO_TEMPLATE_SUBSCRIBER_VOICES=29        # Subscriber nurture: community voices + share (Day 10)

# Brevo template IDs — Community Voices (Artifact 10 §5)
BREVO_TEMPLATE_VOICE_EMAIL_VERIFY=19
BREVO_TEMPLATE_VOICE_APPROVED=20
BREVO_TEMPLATE_VOICE_REJECTED=21
BREVO_TEMPLATE_VOICE_EDITED=22
BREVO_TEMPLATE_VOICE_ADMIN_DIGEST=23

# Brevo template IDs — Admin Notifications (Donation Milestones)
BREVO_TEMPLATE_ADMIN_DONATION_MILESTONE=24  # Optional — admin notification when donation milestones are reached

# --- Anthropic (AI Moderation) ---
# Used by the voice submission moderation pipeline (Claude Haiku 4.5).
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key

# --- ActBlue (Donations) ---
# Embed token is publishable (used in browser for donation widget).
# Webhook credentials are SECRET (HTTP Basic Auth per Artifact 09).
NEXT_PUBLIC_ACTBLUE_EMBED_TOKEN=your-actblue-embed-token
ACTBLUE_WEBHOOK_USERNAME=your-actblue-webhook-username
ACTBLUE_WEBHOOK_PASSWORD=your-actblue-webhook-password

# --- Cloudflare Turnstile ---
# Test keys below always pass — replace with real keys in production.
# See: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side PostHog key (Personal API key — used in API routes and Inngest functions)
# Get from PostHog → Project Settings → Personal API Keys
POSTHOG_API_KEY=phx_your-posthog-server-key

# --- Google Analytics 4 ---
# Consent-gated: only loads after user accepts analytics cookies.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Inngest ---
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# --- Application ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
EMAIL_VERIFICATION_SECRET=generate-with-openssl-rand-hex-32
# Comma-separated list of emails allowed to access /admin
ADMIN_ALLOWED_EMAILS=tim@timfulton.com
